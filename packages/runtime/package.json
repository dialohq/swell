{
  "name": "swell",
  "version": "0.1.0",
  "description": "Statically-typed inline Postgres queries for TypeScript",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./pg": {
      "types": "./dist/pg.d.ts",
      "import": "./dist/pg.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --preload ./test/preload.ts"
  },
  "peerDependencies": {
    "postgres": "^3.4.0",
    "pg": "^8.0.0",
    "pg-query-stream": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "postgres": { "optional": true },
    "pg": { "optional": true },
    "pg-query-stream": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "pg": "^8.0.0",
    "postgres": "^3.4.0"
  }
}
