{
  "name": "swell",
  "version": "0.1.0",
  "description": "Statically-typed inline Postgres queries for TypeScript",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./packages/runtime/dist/index.js",
  "types": "./packages/runtime/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./packages/runtime/dist/index.d.ts",
      "import": "./packages/runtime/dist/index.js"
    },
    "./pg": {
      "types": "./packages/runtime/dist/pg.d.ts",
      "import": "./packages/runtime/dist/pg.js"
    }
  },
  "files": ["packages/runtime/dist", "packages/runtime/package.json"],
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true }
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build:runtime": "bun run --cwd packages/runtime build",
    "typecheck": "bun run --cwd packages/runtime typecheck"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dialohq/swell.git"
  }
}
